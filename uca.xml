<?xml version="1.0" encoding="UTF-8"?>
<actions>
<action>
	<icon>autokey-status</icon>
	<name>Root Open</name>
	<submenu></submenu>
	<unique-id>1746779307306707-2</unique-id>
	<command>sudo thunar %f</command>
	<description></description>
	<range>*</range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>drive-multidisk</icon>
	<name>Mount Virtual Disk - Writable</name>
	<submenu></submenu>
	<unique-id>1762801909224233-1</unique-id>
	<command>bash -c &apos;FILE=&quot;%f&quot;; MP=&quot;/mnt/${FILE##*/}&quot;; sudo mkdir -p &quot;$MP&quot;; LOOP=$(sudo losetup --show -fP &quot;$FILE&quot;); if [ -b &quot;${LOOP}p1&quot; ]; then sudo mount &quot;${LOOP}p1&quot; &quot;$MP&quot;; else sudo mount &quot;$LOOP&quot; &quot;$MP&quot;; fi; echo &quot;Mounted $FILE at $MP&quot;&apos;
</command>
	<description></description>
	<range>*</range>
	<patterns>*.img;*.vhd;*.raw</patterns>
	<other-files/>
</action>
<action>
	<icon>view-list-tree</icon>
	<name>Directory Tree &gt; Clipboard</name>
	<submenu></submenu>
	<unique-id>1747078088003067-3</unique-id>
	<command>bash -c &apos;kdialog --passivepopup &quot;⚠️ Constructing tree...&quot; 2 &amp;&amp; tree -a &quot;%f&quot; | xclip -sel clip &amp;&amp; kdialog --passivepopup &quot;✅ Directory tree copied to clipboard!&quot; 2&apos;</command>
	<description></description>
	<range>*</range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>edit-copy</icon>
	<name>Copy Path To Clipboard</name>
	<submenu></submenu>
	<unique-id>1746778379622825-2</unique-id>
	<command>bash -c &apos;echo -n &quot;%F&quot; | xclip -sel clip &amp;&amp; kdialog --title &quot;✅ Copied!&quot; --passivepopup &quot;$(echo &quot;%F&quot; | wc -w) paths copied&quot; 3&apos;</command>
	<description></description>
	<range>*</range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>utilities-x-terminal</icon>
	<name>Open Terminal Here</name>
	<submenu></submenu>
	<unique-id>1736989118649432-1</unique-id>
	<command>exo-open --working-directory %f --launch TerminalEmulator</command>
	<description></description>
	<range></range>
	<patterns>*</patterns>
	<startup-notify/>
	<directories/>
</action>
<action>
	<icon>peazip</icon>
	<name>.ZIP This Directory </name>
	<submenu></submenu>
	<unique-id>1747080478910947-2</unique-id>
	<command>bash -c &apos;
DIR=&quot;%f&quot; &amp;&amp;
ZIP_NAME=&quot;$(basename &quot;$DIR&quot;).zip&quot; &amp;&amp;
ZIP_PATH=&quot;$(dirname &quot;$DIR&quot;)/$ZIP_NAME&quot; &amp;&amp;
7z a -tzip -mx=9 &quot;$ZIP_PATH&quot; &quot;$DIR&quot; 2&gt;/dev/null &amp;&amp;
kdialog --title &quot;✅ ZIP Complete&quot; --passivepopup &quot;Created: $ZIP_NAME\nLocation: $(dirname &quot;$DIR&quot; | sed &quot;s|$HOME|~|&quot;)&quot; 10
&apos;</command>
	<description></description>
	<range>*</range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>archive</icon>
	<name>Extract Here</name>
	<submenu></submenu>
	<unique-id>1746776148377255-1</unique-id>
	<command>ark --batch --autodestination %f</command>
	<description></description>
	<range>*</range>
	<patterns>*.zip;*.rar;*.7z;*.tar;*.tar.gz;*.tgz;*.tar.bz2;*.tbz2;*.tar.xz;*.txz;*.iso</patterns>
	<image-files/>
	<other-files/>
</action>
<action>
	<icon>/home/x/Pictures/ICONS/qemu-greyfx.png</icon>
	<name>QuickBoot (BIOS) </name>
	<submenu></submenu>
	<unique-id>1747075134582799-1</unique-id>
	<command>sudo bash -c &apos;qemu-system-x86_64 -enable-kvm -m 4G -drive file=&quot;%f&quot;,format=raw -boot order=d -nic user,hostfwd=tcp::2222-:22&apos;</command>
	<description></description>
	<range>*</range>
	<patterns>*.iso;*.img;*.vhd;*.raw</patterns>
	<other-files/>
</action>
<action>
	<icon>/home/x/Pictures/ICONS/qemu-greyfx.png</icon>
	<name>QuickBoot (UEFI)</name>
	<submenu></submenu>
	<unique-id>1747075939393183-2</unique-id>
	<command>sudo bash -c &apos;cp /usr/share/OVMF/OVMF_VARS_4M.fd /tmp/OVMF_VARS_runtime.fd &amp;&amp; qemu-system-x86_64 -enable-kvm -m 4G -drive if=pflash,format=raw,readonly=on,file=/usr/share/OVMF/OVMF_CODE_4M.fd -drive if=pflash,format=raw,file=/tmp/OVMF_VARS_runtime.fd -drive file=&quot;%f&quot;,format=raw -nic user,hostfwd=tcp::2222-:22&apos;</command>
	<description></description>
	<range>*</range>
	<patterns>*.iso;*.img;*.vhd;*.raw</patterns>
	<other-files/>
</action>
<action>
	<icon>application-x-deb</icon>
	<name>Install .deb Package</name>
	<submenu></submenu>
	<unique-id>1748507208431814-1</unique-id>
	<command>x-terminal-emulator -e &quot;bash -c &apos;echo Installing %f; sudo apt install -y %f; echo; echo Installation complete; echo Press Enter to close...; read&apos;&quot;</command>
	<description></description>
	<range>*</range>
	<patterns>*.deb</patterns>
	<other-files/>
</action>
<action>
	<icon>text-x-fsharp</icon>
	<name>Execute Bash</name>
	<submenu></submenu>
	<unique-id>1746778447272640-3</unique-id>
	<command>xfce4-terminal -e &quot;bash -c &apos;if [[ \&quot;%f\&quot; == *.sh ]]; then bash \&quot;%f\&quot;; elif [[ \&quot;%f\&quot; == *.py ]]; then python3 \&quot;%f\&quot;; fi; read -p \&quot;Press [Enter] to close...\&quot;&apos;&quot;</command>
	<description></description>
	<range>*</range>
	<patterns>*.sh</patterns>
	<other-files/>
	<text-files/>
</action>
<action>
	<icon>python</icon>
	<name>Execute Python</name>
	<submenu></submenu>
	<unique-id>1746779055456787-1</unique-id>
	<command>xfce4-terminal -e &quot;bash -c &apos;if [[ \&quot;%f\&quot; == *.sh ]]; then bash \&quot;%f\&quot;; elif [[ \&quot;%f\&quot; == *.py ]]; then python3 \&quot;%f\&quot;; fi; read -p \&quot;Press [Enter] to close...\&quot;&apos;&quot;</command>
	<description></description>
	<range>*</range>
	<patterns>*.py</patterns>
	<text-files/>
</action>
<action>
	<icon>network-transmit</icon>
	<name>Send to Glitch-Server</name>
	<submenu></submenu>
	<unique-id>1775845809794201-1</unique-id>
	<command>bash -c &apos;scp -P 2222 &quot;%f&quot; x@glitchserver.com:/FILES/RECEIVED/ &amp;&amp; kdialog --passivepopup &quot; Sent: %n → gLiTcH-SERVER:/FILES/RECEIVED/&quot; 4 || kdialog --passivepopup &quot; Transfer failed: %n&quot; 4&apos;</command>
	<description>Send file to glitchserver.com:/FILES/RECEIVED/</description>
	<range>*</range>
	<patterns>*</patterns>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>network-transmit</icon>
	<name>Send to Contabo-Vps</name>
	<submenu></submenu>
	<unique-id>1775845809794202-2</unique-id>
	<command>bash -c &apos;scp &quot;%f&quot; x@glitchlinux.com:/home/x/Desktop/RECEIVED/ &amp;&amp; kdialog --passivepopup &quot; Sent: %n → Contabo:/home/x/Desktop/RECEIVED/&quot; 4 || kdialog --passivepopup &quot; Transfer failed: %n&quot; 4&apos;</command>
	<description>Send file to glitchlinux.com:/home/x/Desktop/RECEIVED/</description>
	<range>*</range>
	<patterns>*</patterns>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>btrfs-assistant</icon>
	<name>Make Executable</name>
	<submenu></submenu>
	<unique-id>1747079720055029-1</unique-id>
	<command>bash -c &apos;if [ ! -x &quot;%f&quot; ]; then chmod +x &quot;%f&quot; &amp;&amp; kdialog --passivepopup &quot;Made executable: %f&quot; 3; fi&apos;</command>
	<description></description>
	<range>*</range>
	<patterns>*.sh;*.py</patterns>
	<other-files/>
	<text-files/>
</action>
<action>
	<icon>account-edit</icon>
	<name>Nano Edit</name>
	<submenu></submenu>
	<unique-id>1746780400379011-3</unique-id>
	<command>bash -c &apos;xfce4-terminal -x nano &quot;%f&quot;&apos;</command>
	<description></description>
	<range>*</range>
	<patterns>*</patterns>
	<other-files/>
	<text-files/>
</action>
<action>
	<icon>gtk-dialog-warning-panel</icon>
	<name>Root Delete</name>
	<submenu></submenu>
	<unique-id>1748510121574965-1</unique-id>
	<command>if zenity --question --title=&quot;ROOT DELETE&quot; --text=&quot;PERMANENTLY delete as root?\n\n%N&quot; --ok-label=&quot;DELETE&quot; --cancel-label=&quot;Cancel&quot;; then
    x-terminal-emulator -e &quot;sudo rm -rf %F&quot;
fi</command>
	<description></description>
	<range>*</range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>mx-user</icon>
	<name>Take Ownership</name>
	<submenu></submenu>
	<unique-id>1775845809794128-1</unique-id>
	<command>pkexec chown -Rf $USER %f</command>
	<description>Change ownership of file/folder to current user</description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
<action>
	<icon>data-warning</icon>
	<name>Paste as Root</name>
	<submenu></submenu>
	<unique-id>1775845809794177-3</unique-id>
	<command>echo &quot;cp -r /tmp/.thunar_root_copy %f&quot; &gt; /tmp/thunar_action.sh &amp;&amp; sudo bash /tmp/thunar_action.sh
</command>
	<description></description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
